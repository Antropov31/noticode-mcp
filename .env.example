# NotiCode configuration

# Required for chat, telegram, and all modes (where NotiCode calls the model
# itself). NOT needed for `noticode mcp` or `noticode serve` -- in those modes
# your MCP client (Claude, Cursor, ...) brings the model.
ANTHROPIC_API_KEY=sk-ant-...

# Root directory the agent is allowed to operate in. Defaults to the current dir.
NOTICODE_WORKSPACE=/absolute/path/to/your/project

# HTTP server (used by `noticode serve` and `noticode all`).
NOTICODE_HOST=127.0.0.1
NOTICODE_PORT=4319
# Optional bearer token to protect the HTTP endpoint. Leave empty for no auth.
NOTICODE_TOKEN=

# Anthropic model used in chat, telegram, and all modes.
NOTICODE_MODEL=claude-sonnet-4-20250514

# Safety switches. Set to "false" to lock things down.
NOTICODE_ALLOW_SHELL=true
NOTICODE_ALLOW_WRITE=true

# Max characters returned from a single tool call.
NOTICODE_MAX_OUTPUT=30000

# --- Telegram bot (used by `noticode telegram`, `noticode all`, tg_* tools) ---
# Bot token from @BotFather. Required to run the bot or use the tg tools.
TELEGRAM_BOT_TOKEN=
# Optional. Your chat ID. If set, the bot only answers this chat and
# tg_send / notify use it as the default target. Message @userinfobot for it.
TELEGRAM_CHAT_ID=

# --- Home Assistant (used by ha_states / ha_call_service) ---
# Base URL of your Home Assistant instance.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
# Long-lived access token (HA profile page -> Long-lived access tokens).
HOME_ASSISTANT_TOKEN=
