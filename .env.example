# NotiCode configuration

# Required for `noticode chat` (the interactive agent).
ANTHROPIC_API_KEY=sk-ant-...

# Root directory the agent is allowed to operate in. Defaults to the current dir.
NOTICODE_WORKSPACE=/absolute/path/to/your/project

# Anthropic model used in chat mode.
NOTICODE_MODEL=claude-sonnet-4-20250514

# Safety switches. Set to "false" to lock things down.
NOTICODE_ALLOW_SHELL=true
NOTICODE_ALLOW_WRITE=true

# Max characters returned from a single tool call.
NOTICODE_MAX_OUTPUT=30000

# --- Machine access (no extra config required) -------------------------------
# The agent can also see and drive the machine it runs on:
#   screen_capture   grab a screenshot of your display
#   webcam_capture   grab a still from your webcam
#   browser_*        drive a headless Chromium (navigate/click/type/eval/screenshot)
# Captures are written to <workspace>/.noticode/captures.
# These rely on optional deps installed via `npm install`
# (screenshot-desktop, node-webcam) plus Playwright's browser binary:
#   npx playwright install chromium
# On Linux, webcam capture needs fswebcam or ffmpeg; on macOS, imagesnap.
