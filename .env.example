# NotiCode configuration

# Required for `noticode chat` (the interactive agent). Not needed for `mcp`/`serve`.
ANTHROPIC_API_KEY=sk-ant-...

# Root directory the agent is allowed to operate in. Defaults to the current dir.
NOTICODE_WORKSPACE=/absolute/path/to/your/project

# Anthropic model used in chat mode.
NOTICODE_MODEL=claude-sonnet-4-20250514

# Safety switches. Set to "false" to lock things down.
NOTICODE_ALLOW_SHELL=true
NOTICODE_ALLOW_WRITE=true

# Max characters returned from a single tool call.
NOTICODE_MAX_OUTPUT=30000

# --- HTTP transport (`noticode serve`) ---------------------------------------
# Exposes the MCP server at http://HOST:PORT/mcp so any HTTP MCP client can
# connect. No API key needed (the client brings the model).
NOTICODE_HOST=127.0.0.1
NOTICODE_PORT=4319
# Set a token before exposing the server beyond localhost. Clients must then
# send `Authorization: Bearer <token>`.
# NOTICODE_TOKEN=change-me

# --- Home Assistant (enables ha_states / ha_call_service) --------------------
# HOME_ASSISTANT_URL=http://homeassistant.local:8123
# HOME_ASSISTANT_TOKEN=long-lived-access-token

# --- Machine access (no config required) -------------------------------------
# The agent can also see and drive the machine it runs on:
#   screen_capture / screen_watch   screenshot, or a timed series with change detection
#   webcam_capture                  still from the webcam
#   input_move/click/type/key/scroll  control the mouse + keyboard
#   clipboard_read / clipboard_write  read/write the system clipboard
#   mic_capture / audio_play          record the mic / play a sound
#   os_notify                         native desktop notification
#   fs_watch                          watch a directory for changes
#   browser_*                         drive a headless Chromium
# Captures/recordings are written under <workspace>/.noticode/.
# These rely on optional deps installed via `npm install`:
#   @nut-tree-fork/nut-js, clipboardy, node-notifier, node-record-lpcm16,
#   play-sound, screenshot-desktop, node-webcam, playwright
# Plus Playwright's browser binary: `npx playwright install chromium`.
# Platform notes: input control on Linux needs libxtst + an X session;
# mic_capture needs SoX; webcam needs fswebcam/ffmpeg (Linux) or imagesnap (macOS).
