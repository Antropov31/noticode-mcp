# NotiCode configuration

# Required ONLY for `noticode chat` (the built-in terminal agent that calls the
# model itself). NOT needed for `noticode mcp` or `noticode serve` — in those
# modes your MCP client (Claude, Cursor, ...) brings the model.
ANTHROPIC_API_KEY=sk-ant-...

# Root directory the agent is allowed to operate in. Defaults to the current dir.
NOTICODE_WORKSPACE=/absolute/path/to/your/project

# HTTP server (used by `noticode serve`).
NOTICODE_HOST=127.0.0.1
NOTICODE_PORT=4319
# Optional bearer token to protect the HTTP endpoint. Leave empty for no auth.
NOTICODE_TOKEN=

# Anthropic model used in chat mode.
NOTICODE_MODEL=claude-sonnet-4-20250514

# Safety switches. Set to "false" to lock things down.
NOTICODE_ALLOW_SHELL=true
NOTICODE_ALLOW_WRITE=true

# Max characters returned from a single tool call.
NOTICODE_MAX_OUTPUT=30000
