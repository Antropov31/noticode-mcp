{
  "name": "noticode",
  "version": "0.1.0",
  "description": "A blue, open AI coding agent that runs as an MCP server. Connect Claude or any MCP client, chat with it, and let it edit files and control your machine.",
  "type": "module",
  "bin": {
    "noticode": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "mcp": "node dist/index.js mcp",
    "serve": "node dist/index.js serve",
    "chat": "node dist/index.js chat",
    "telegram": "node dist/index.js telegram",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "coding-agent",
    "claude",
    "llm",
    "cli",
    "telegram",
    "telegram-bot"
  ],
  "author": "Antropov31",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.3.0",
    "express": "^4.21.2",
    "fast-glob": "^3.3.2",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
